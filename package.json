{
  "name": "portfolio",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "test": "ng test",
    "lint": "ng lint",
    "build": "ng build",
    "update": "pnpm self-update && pnpm update && pnpm audit && pnpm update --latest --interactive",
    "translations": "ngx-translate-extract -i ./src -o ./src/assets/i18n{/en,/nl}.json -c -s -k -f namespaced-json --fi \"  \"",
