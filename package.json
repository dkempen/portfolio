    "@angular/cli": "~21.2.2",
    "@angular/compiler-cli": "^21.2.4",
    "@angular/localize": "^21.2.4",
    "@types/jasmine": "~6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vendure/ngx-translate-extract": "^10.1.3",
    "eslint": "^10.0.3",
    "jasmine-core": "~6.1.0",
