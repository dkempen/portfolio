    "@angular/router": "^21.2.4",
    "@angular/service-worker": "^21.2.4",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@popperjs/core": "^2.11.8",
